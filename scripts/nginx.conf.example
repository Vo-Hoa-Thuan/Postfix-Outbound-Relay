server {
    listen 80;
    server_name mailpanel.yourdomain.com; # Thay thế bằng domain thực tế

    # Chuyển hướng ngay sang HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name mailpanel.yourdomain.com; # Thay thế bằng domain thực tế

    # Đường dẫn SSL (Hãy sinh SSL bằng Certbot/Let's Encrypt trước)
    # ssl_certificate /etc/letsencrypt/live/mailpanel.yourdomain.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/mailpanel.yourdomain.com/privkey.pem;

    # Cấu hình bảo mật tốt cho SSL
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;

    # Cấu hình log riêng cho Panel
    access_log /var/log/nginx/postfix_panel_access.log;
    error_log /var/log/nginx/postfix_panel_error.log;

    location / {
        # Nếu dùng Unix socket ở Systemd (Proxy pass tới sock)
        # proxy_pass http://unix:/opt/Postfix-Outbound-Relay/postfix_panel.sock;
        
        # Nếu dùng port 8000 cho Gunicorn:
        proxy_pass http://127.0.0.1:8000;
        
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Hỗ trợ Websocket nếu sau này app cần realtime logs
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # Chặn các request rác phổ biến
    location ~ /\.ht {
        deny all;
    }
}
